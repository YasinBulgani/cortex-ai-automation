# ═════════════════════════════════════════════════════════════════════════════
#  Pipeline Conductor — LLM Provider Ayarları
#  .env dosyasına kopyala, gereğe göre düzenle.
# ═════════════════════════════════════════════════════════════════════════════

# ─── Provider Seçimi ─────────────────────────────────────────────────────────
# ollama  — lokal LLM (default, token gerekmez, en hızlı, gizli)
# huggingface — cloud, ücretsiz tier, token gerekir
LLM_PROVIDER=ollama

# ═════════════════════════════════════════════════════════════════════════════
# OLLAMA (LOKAL — VARSAYILAN)
# ═════════════════════════════════════════════════════════════════════════════

OLLAMA_HOST=http://localhost:11434
OLLAMA_KEEP_ALIVE=-1                     # bellekte tut (0=anında boşalt, "5m"=5dk)
OLLAMA_TIMEOUT_S=180                     # 32B modeller için yeterli

# Rol tier → model mapping
OLLAMA_DEFAULT_MODEL=qwen2.5:14b         # balanced roles (proposer, approver, designer, ...)
OLLAMA_POWERFUL_MODEL=qwen2.5:32b        # kritik kararlar (architect, security, qa, promoter)
OLLAMA_FAST_MODEL=llama3.1:8b            # hızlı roller (analyzer, validator, observer)
OLLAMA_CODER_MODEL=qwen2.5-coder:7b      # kod rolleri (frontend, backend, data, devops)

# ═════════════════════════════════════════════════════════════════════════════
# HUGGINGFACE (CLOUD — ALTERNATİF)
# ═════════════════════════════════════════════════════════════════════════════
# Kullanmak için LLM_PROVIDER=huggingface yap
# Token al: https://huggingface.co/welcome → Settings → Access Tokens (Read tier)

# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx
# HF_DEFAULT_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# HF_POWERFUL_MODEL=meta-llama/Meta-Llama-3-70B-Instruct
# HF_FAST_MODEL=Qwen/Qwen2.5-7B-Instruct
# HF_CODER_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# ═════════════════════════════════════════════════════════════════════════════
# DASHBOARD
# ═════════════════════════════════════════════════════════════════════════════

# PIPELINE_DASHBOARD_HOST=127.0.0.1
# PIPELINE_DASHBOARD_PORT=8765
