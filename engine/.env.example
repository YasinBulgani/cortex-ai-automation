# BGTS Test Automation Engine — Environment Variables
# Root .env dosyası da okunur, burada sadece engine'e özel değerleri tanımlayın.

# AI / LLM
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=

# Browser
BROWSER=chromium
HEADLESS=false
BASE_URL=https://example.com

# Timeouts (ms)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000

# Engine Server
ENGINE_PORT=5001
ENGINE_SECRET_KEY=change-me-engine-secret

# Backend iç servis anahtarı — backend/.env.example'daki ENGINE_INTERNAL_KEY ile aynı olmalı
ENGINE_INTERNAL_KEY=bgts-internal-key-change-me
