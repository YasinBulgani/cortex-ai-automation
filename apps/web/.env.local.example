# Next.js bu dosyayı otomatik yüklemez; kopyalayın:
#   cp .env.local.example .env.local
# Kök dizindeki .env tek başına Next tarafından okunmaz (next.config apps/web altında).

# ── Standart API sözleşmesi ───────────────────────────────────────────
# Tüm frontend `apiFetch` / `engineFetch` bu base URL'leri kullanır.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
NEXT_PUBLIC_ENGINE_BASE=http://127.0.0.1:5001

# AI Gateway tarayıcıdan direkt çağrılmaz; Next.js /api/ai proxy bu server-only
# değerlerle gateway'e bağlanır ve X-Internal-Key'i client bundle'a sızdırmaz.
AI_GATEWAY_BASE_URL=http://127.0.0.1:8080
GATEWAY_INTERNAL_KEY=nexusqa-gateway-internal-key-change-me

# Flask Engine (port 5001) X-Internal-Key. /api/engine/* Next.js proxy
# (RecorderStudio, ConversationalTestCreator) bu değeri server-side ekler.
# MUST match backend/.env ENGINE_INTERNAL_KEY. Never prefix NEXT_PUBLIC_.
ENGINE_BASE_URL=http://127.0.0.1:5001
ENGINE_INTERNAL_KEY=twai-internal-key-change-me

# ── Deprecated ────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL artık KULLANIMDAN KALDIRILDI. Bunun yerine NEXT_PUBLIC_API_BASE kullanın.
# NEXT_PUBLIC_ENGINE_URL yerine NEXT_PUBLIC_ENGINE_BASE kullanın.
