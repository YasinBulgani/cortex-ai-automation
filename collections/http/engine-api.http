# DATASIM — Sentetik Veri Simülasyonu
###############################################################################

### List Dataset Catalog
GET {{engine_url}}/api/datasim/datasets

### Load Dataset
POST {{engine_url}}/api/datasim/datasets/load
Content-Type: application/json

{
    "id": "banking_transactions",
    "sample_rows": 50
}

### Check Mostly AI Install
GET {{engine_url}}/api/datasim/check-install

### SQLite/PG Catalog
GET {{engine_url}}/api/datasim/sqlite/catalog

### Get DB Tables
POST {{engine_url}}/api/datasim/sqlite/tables
Content-Type: application/json

{
    "id": "banking_full"
}

### Preview Table Data
POST {{engine_url}}/api/datasim/sqlite/preview
Content-Type: application/json

{
    "id": "banking_full",
    "table": "customers",
    "limit": 20
}

