# Nexus QA AI Gateway — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve API key'lerinizi ekleyin
# cp .env.example .env

# ── Servis ──────────────────────────────────────────────────────────────────
PORT=8080
DEBUG=false
INTERNAL_KEY=nexusqa-gateway-internal-key-change-me

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1

# ── Groq (Ücretsiz API Key: https://console.groq.com) ───────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-70b-8192
GROQ_ENABLED=true

# ── Gemini (Ücretsiz API Key: https://aistudio.google.com/app/apikey) ───────
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-flash
GEMINI_ENABLED=true

# ── Ollama (Local — https://ollama.ai) ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_FALLBACK_MODEL=mistral
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_ENABLED=true

# ── vLLM (Self-hosted, Açık Kaynak — https://docs.vllm.ai) ──────────────────
# PagedAttention + continuous batching ile SOTA open-weight modelleri sun.
# Başlatma örneği:
#   docker run --gpus all -p 8000:8000 vllm/vllm-openai \
#     --model Qwen/Qwen2.5-72B-Instruct --dtype bfloat16
# AI_PROVIDER=vllm ile zincirin başına alınır; auto mode'da da VLLM_ENABLED=true
# yeterlidir (vLLM > Groq > Gemini > Ollama sırası).
VLLM_ENABLED=false
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=                                   # vLLM --api-key ile başlatıldıysa
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct
VLLM_TIMEOUT_SECONDS=120
