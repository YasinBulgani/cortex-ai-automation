# ─── Ürün markası (UX-F1-105 — tek kaynak APP_NAME) ──────────────────────────
# Frontend'deki NEXT_PUBLIC_APP_NAME ile aynı değere ayarlayın. Boş kalırsa
# FastAPI title default "Sentetik Veri Platformu" olur.
# Örnek: APP_NAME=TestwrightAI
APP_NAME=

DATABASE_URL=postgresql+psycopg2://twai_user:twai_pass@127.0.0.1:5432/syndata_db
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET=CHANGEME-minimum-64-chars-use-openssl-rand-base64-64
ARTIFACTS_DIR=./data/artifacts
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173

# Engine bağlantısı
# Docker ortamı: ENGINE_BASE_URL=http://engine:5001
# Yerel geliştirme: ENGINE_BASE_URL=http://127.0.0.1:5001
ENGINE_BASE_URL=http://127.0.0.1:5001
ENGINE_INTERNAL_KEY=twai-internal-key-change-me

# AI Sağlayıcısı: "openai" | "anthropic" | "ollama"
# Ücretsiz lokal kullanım için "ollama" seçin (key gerekmez)
AI_PROVIDER=ollama
# true ise secili provider eksik oldugunda uygun baska provider'a log yazarak duser
ALLOW_PROVIDER_FALLBACK=false

# Ollama — lokal, ücretsiz, key yok
# Docker içinden host makineye erişim: host.docker.internal
# Yerel geliştirmede: http://127.0.0.1:11434/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen2.5:14b   # qwen2.5:32b indikten sonra değiştir

# OpenAI (ücretli — opsiyonel)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic (ücretli — opsiyonel)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_GATEWAY_BASE_URL=http://127.0.0.1:8080
GATEWAY_INTERNAL_KEY=nexusqa-gateway-internal-key-change-me

# DSL Sözlüğü — AI semantic search
# Embedding modelinin adı (gateway'in de bildiği isim). Değiştirirseniz
# `make dsl-ai-warm OLLAMA_EMBED_MODEL=<model>` ile ısıtın.
DSL_EMBEDDING_MODEL=bge-m3

# ── DSL Reranker (OPSİYONEL) ─────────────────────────────────────────────────
# bge-m3 dense retrieval sonrası cross-encoder ile yeniden sıralama.
# Türkçe parafraz eşleşmelerini güçlendirir — eval raporunda %86.4 mapping
# accuracy'nin %13.6'lık unknown/yanlış dilimini hedefler.
#
# Açmak için:
#   1. AI_MODEL_RERANKER_ENABLED=true
#   2. backend/requirements.txt içinde `sentence-transformers>=3.0,<4.0`
#      satırının yorumunu kaldırın ve `pip install -r requirements.txt`
#   3. (Opsiyonel) Farklı bir Türkçe/multi reranker için AI_MODEL_RERANKER override
# Kurulu değil veya kapalıysa: sessiz pass-through, arama yolu değişmez.
AI_MODEL_RERANKER_ENABLED=false
AI_MODEL_RERANKER=seroe/bge-reranker-v2-m3-turkish-triplet
AI_MODEL_RERANKER_TOP_K_IN=20
AI_MODEL_RERANKER_TOP_K_OUT=5
AI_MODEL_RERANKER_DEVICE=cpu   # cpu | cuda | mps (Apple Silicon)

# DSL Sözlüğü — Düzenleyici / Git
# DSL_GIT_ENABLED=false iken editör değişiklikleri YAML'e yazılır ama git
# commit atılmaz. Dev ortamında böyle bırakabilirsiniz; prod için true.
DSL_GIT_ENABLED=false
# direct_commit: aktif branch'e commit (+ DSL_GIT_DIRECT_PUSH true ise push)
# pr           : dsl/edit-<slug> branch'i + GitHub/Gitea PR
DSL_GIT_MODE=direct_commit
DSL_GIT_DIRECT_PUSH=false
DSL_GIT_REMOTE=origin
DSL_GIT_BASE_BRANCH=main
DSL_GIT_BRANCH_PREFIX=dsl/edit-
DSL_GIT_STRICT_CLEAN=true
DSL_GIT_AUTHOR_NAME=DSL Bot
[email protected]

# Git provider — GitHub veya Gitea (PR modu için gereklidir)
DSL_GIT_PROVIDER=github
# Reviewer'lar virgülle ayrılmış GitHub kullanıcı adlarıdır.
DSL_GIT_GITHUB_REPO=YasinBulgani/BGTS-Test-Donusum
DSL_GIT_REVIEWERS=
# GITHUB_TOKEN ayrıca yukarıda webhook bölümünde tanımlıdır (GITHUB_WEBHOOK_SECRET farklı şeydir)

# Gitea alternatifi (opsiyonel)
GITEA_BASE_URL=
GITEA_TOKEN=
DSL_GIT_GITEA_REPO=

AI_BACKGROUND_ENABLED=true
AI_BACKGROUND_INTERVAL_SECONDS=900
AI_BACKGROUND_START_DELAY_SECONDS=60
AI_BACKGROUND_TARGETS=backend=http://backend:8000/health,engine=http://engine:5001/health,ai_gateway=http://ai-gateway:8080/ai/health
AI_BACKGROUND_REPORT_PATH=./data/ai-ops/latest.md

# n8n otomasyon (opsiyonel)
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# E-posta bildirimleri (opsiyonel — SMTP)
# Gmail örneği: smtp_host=smtp.gmail.com, port=587, TLS=true
# App password: myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# GitHub — DSL editörünün PR açmak için kullandığı personal access token
# Repo scope (veya fine-grained: pull_requests:write + contents:write) gerekir.
GITHUB_TOKEN=

# CI/CD Webhook entegrasyonu (opsiyonel)
# GitHub: repo Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=
# GitLab: project Settings → Webhooks → Secret Token
GITLAB_WEBHOOK_TOKEN=
# Jenkins: Notification plugin token
JENKINS_WEBHOOK_TOKEN=

# Docker entrypoint: RUN_SEED_DEMO=1 → scripts/seed_demo.py (simülasyon dataset + örnek iş)
# Yerel: cd backend && PYTHONPATH=. python scripts/seed_demo.py
