#!/usr/bin/env bash
# =============================================================================
# neurex — NeurexQA Servis Yönetim CLI
# =============================================================================
# Kullanım:
#   neurex up          Tüm servisleri başlat
#   neurex down        Tüm servisleri durdur
#   neurex restart     Tüm servisleri yeniden başlat
#   neurex status      Servis durumlarını göster
#   neurex logs        Canlı log takibi
#   neurex install     Mac açılışında otomatik başlat (LaunchAgent kur)
#   neurex uninstall   LaunchAgent'ı kaldır
#   neurex clean       Playwright zombie'lerini temizle
# =============================================================================

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$PROJECT_ROOT/.env"
WATCHDOG_SCRIPT="$SCRIPT_DIR/neurex-watchdog.sh"
WATCHDOG_PID_FILE="/tmp/neurex-watchdog.pid"
LAUNCH_AGENT_LABEL="com.neurexqa.watchdog"
LAUNCH_AGENT_PLIST="$HOME/Library/LaunchAgents/${LAUNCH_AGENT_LABEL}.plist"

VENV_PYTHON="$PROJECT_ROOT/.venv/bin/python"
SYSTEM_PYTHON="/opt/homebrew/bin/python3.11"
BACKEND_PORT=8000
ENGINE_PORT=5001

# Renk kodları
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

# ── Yardımcılar ───────────────────────────────────────────────────────────────
ok()   { echo -e "  ${GREEN}✅${NC} $*"; }
warn() { echo -e "  ${YELLOW}⚠️ ${NC} $*"; }
err()  { echo -e "  ${RED}❌${NC} $*"; }
info() { echo -e "  ${CYAN}→${NC} $*"; }

load_env() {
    [ -f "$ENV_FILE" ] && { set -a; source "$ENV_FILE"; set +a; } || true
}

is_healthy() {
    curl -sf --max-time 5 "http://localhost:$1/health" > /dev/null 2>&1
}

port_pid() {
    lsof -ti :"$1" 2>/dev/null | head -1 || echo ""
}

# ── up ────────────────────────────────────────────────────────────────────────
cmd_up() {
    echo -e "\n${BOLD}${CYAN}NeurexQA Servisleri Başlatılıyor...${NC}\n"
    load_env

    local python_bin="$SYSTEM_PYTHON"
    [ -f "$VENV_PYTHON" ] && python_bin="$VENV_PYTHON"

    # Backend
    if is_healthy "$BACKEND_PORT"; then
        ok "Backend zaten çalışıyor (port $BACKEND_PORT)"
    else
        info "Backend başlatılıyor..."
        cd "$PROJECT_ROOT/backend"
        nohup "$python_bin" -m uvicorn app.main:app \
            --host 127.0.0.1 --port "$BACKEND_PORT" \
            >> /tmp/neurex-backend.log 2>&1 &
        echo $! > /tmp/neurex-backend.pid
        local i=0
        while [ $i -lt 15 ] && ! is_healthy "$BACKEND_PORT"; do sleep 1; i=$((i+1)); done
        is_healthy "$BACKEND_PORT" && ok "Backend hazır (port $BACKEND_PORT)" || err "Backend başlatılamadı — log: /tmp/neurex-backend.log"
    fi

    # Engine
    if is_healthy "$ENGINE_PORT"; then
        ok "Engine zaten çalışıyor (port $ENGINE_PORT)"
    else
        info "Engine başlatılıyor..."
        cd "$PROJECT_ROOT/engine"
        nohup "$VENV_PYTHON" app.py \
            >> /tmp/neurex-engine.log 2>&1 &
        echo $! > /tmp/neurex-engine.pid
        local i=0
        while [ $i -lt 15 ] && ! is_healthy "$ENGINE_PORT"; do sleep 1; i=$((i+1)); done
        is_healthy "$ENGINE_PORT" && ok "Engine hazır (port $ENGINE_PORT)" || err "Engine başlatılamadı — log: /tmp/neurex-engine.log"
    fi

    # Watchdog
    if [ -f "$WATCHDOG_PID_FILE" ] && kill -0 "$(cat "$WATCHDOG_PID_FILE")" 2>/dev/null; then
        ok "Watchdog zaten çalışıyor (PID: $(cat "$WATCHDOG_PID_FILE"))"
    else
        info "Watchdog başlatılıyor..."
        nohup bash "$WATCHDOG_SCRIPT" >> /tmp/neurex-watchdog.log 2>&1 &
        ok "Watchdog başlatıldı (PID: $!)"
    fi

    echo ""
    cmd_status
}

# ── down ──────────────────────────────────────────────────────────────────────
cmd_down() {
    echo -e "\n${BOLD}${YELLOW}NeurexQA Servisleri Durduruluyor...${NC}\n"

    # Watchdog
    if [ -f "$WATCHDOG_PID_FILE" ]; then
        kill "$(cat "$WATCHDOG_PID_FILE")" 2>/dev/null && ok "Watchdog durduruldu" || true
        rm -f "$WATCHDOG_PID_FILE"
    fi

    # Backend
    pkill -f "uvicorn app.main:app" 2>/dev/null && ok "Backend durduruldu" || info "Backend zaten durmuş"
    rm -f /tmp/neurex-backend.pid

    # Engine
    pkill -f "python app.py" 2>/dev/null && ok "Engine durduruldu" || info "Engine zaten durmuş"
    rm -f /tmp/neurex-engine.pid

    # Playwright artıkları
    local zombie_count
    zombie_count=$(pgrep -c -f "chrome-headless-shell" 2>/dev/null || echo 0)
    if [ "$zombie_count" -gt 0 ]; then
        pkill -9 -f "chrome-headless-shell" 2>/dev/null || true
        pkill -9 -f "playwright/driver/node" 2>/dev/null || true
        ok "$zombie_count Playwright process temizlendi"
    fi

    echo ""
}

# ── restart ───────────────────────────────────────────────────────────────────
cmd_restart() {
    cmd_down
    sleep 2
    cmd_up
}

# ── status ────────────────────────────────────────────────────────────────────
cmd_status() {
    echo -e "${BOLD}${BLUE}━━━ NeurexQA Servis Durumu ━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    # Backend
    if is_healthy "$BACKEND_PORT"; then
        local pid; pid=$(port_pid "$BACKEND_PORT")
        ok "Backend        → http://localhost:$BACKEND_PORT  (PID: $pid)"
    else
        err "Backend        → DURDU (port $BACKEND_PORT)"
    fi

    # Engine
    if is_healthy "$ENGINE_PORT"; then
        local pid; pid=$(port_pid "$ENGINE_PORT")
        ok "Engine         → http://localhost:$ENGINE_PORT  (PID: $pid)"
    else
        err "Engine         → DURDU (port $ENGINE_PORT)"
    fi

    # Watchdog
    if [ -f "$WATCHDOG_PID_FILE" ] && kill -0 "$(cat "$WATCHDOG_PID_FILE")" 2>/dev/null; then
        ok "Watchdog       → Çalışıyor (PID: $(cat "$WATCHDOG_PID_FILE"))"
    else
        warn "Watchdog       → Çalışmıyor"
    fi

    # LaunchAgent
    if launchctl list "$LAUNCH_AGENT_LABEL" > /dev/null 2>&1; then
        ok "LaunchAgent    → Kurulu (Mac açılışında otomatik başlar)"
    else
        warn "LaunchAgent    → Kurulmamış  (neurex install ile kur)"
    fi

    # Playwright zombies
    local zombie_count
    zombie_count=$(pgrep -c -f "chrome-headless-shell" 2>/dev/null || echo 0)
    if [ "$zombie_count" -gt 0 ]; then
        warn "Playwright     → $zombie_count aktif chrome-headless-shell (neurex clean)"
    else
        ok "Playwright     → Temiz (zombie yok)"
    fi

    # PostgreSQL
    if lsof -i :5432 -sTCP:LISTEN > /dev/null 2>&1; then
        ok "PostgreSQL     → Çalışıyor (port 5432)"
    else
        err "PostgreSQL     → DURDU"
    fi

    # Redis
    if lsof -i :6379 -sTCP:LISTEN > /dev/null 2>&1; then
        ok "Redis          → Çalışıyor (port 6379)"
    else
        err "Redis          → DURDU"
    fi

    echo ""
    echo -e "${BOLD}${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# ── logs ──────────────────────────────────────────────────────────────────────
cmd_logs() {
    local service="${1:-all}"
    echo -e "${CYAN}Loglar izleniyor... (Çıkmak için Ctrl+C)${NC}\n"
    case "$service" in
        backend)  tail -f /tmp/neurex-backend.log ;;
        engine)   tail -f /tmp/neurex-engine.log ;;
        watchdog) tail -f /tmp/neurex-watchdog.log ;;
        all|*)
            tail -f /tmp/neurex-backend.log /tmp/neurex-engine.log /tmp/neurex-watchdog.log 2>/dev/null ;;
    esac
}

# ── clean ─────────────────────────────────────────────────────────────────────
cmd_clean() {
    echo -e "\n${CYAN}Playwright zombie'leri temizleniyor...${NC}"
    local count
    count=$(pgrep -c -f "chrome-headless-shell" 2>/dev/null || echo 0)
    if [ "$count" -gt 0 ]; then
        pkill -9 -f "chrome-headless-shell" 2>/dev/null || true
        pkill -9 -f "playwright/driver/node" 2>/dev/null || true
        ok "$count Playwright process temizlendi"
    else
        ok "Temizlenecek bir şey yok"
    fi
    echo ""
}

# ── install ───────────────────────────────────────────────────────────────────
cmd_install() {
    echo -e "\n${BOLD}${CYAN}LaunchAgent Kuruluyor...${NC}\n"

    mkdir -p "$HOME/Library/LaunchAgents"

    cat > "$LAUNCH_AGENT_PLIST" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${LAUNCH_AGENT_LABEL}</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${WATCHDOG_SCRIPT}</string>
    </array>

    <!-- Mac açılınca çalış -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Çökerse yeniden başlat -->
    <key>KeepAlive</key>
    <true/>

    <!-- Çok hızlı restart'ı önle -->
    <key>ThrottleInterval</key>
    <integer>15</integer>

    <!-- Log dosyaları -->
    <key>StandardOutPath</key>
    <string>/tmp/neurex-watchdog.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/neurex-watchdog-error.log</string>

    <!-- Arka plan görevi -->
    <key>ProcessType</key>
    <string>Background</string>

    <!-- Ortam değişkenleri -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>${HOME}</string>
    </dict>
</dict>
</plist>
PLIST

    # Aktif et
    launchctl unload "$LAUNCH_AGENT_PLIST" 2>/dev/null || true
    launchctl load -w "$LAUNCH_AGENT_PLIST"

    ok "LaunchAgent kuruldu: $LAUNCH_AGENT_PLIST"
    ok "Mac her açıldığında watchdog otomatik başlayacak"
    ok "Watchdog backend ve engine'i otomatik ayağa kaldıracak"
    echo ""
    info "Kaldırmak için: neurex uninstall"
    echo ""
}

# ── uninstall ─────────────────────────────────────────────────────────────────
cmd_uninstall() {
    echo -e "\n${YELLOW}LaunchAgent kaldırılıyor...${NC}\n"
    launchctl unload "$LAUNCH_AGENT_PLIST" 2>/dev/null && ok "LaunchAgent devre dışı bırakıldı" || true
    rm -f "$LAUNCH_AGENT_PLIST" && ok "Plist dosyası silindi" || true
    echo ""
}

# ── Yardım ────────────────────────────────────────────────────────────────────
cmd_help() {
    echo ""
    echo -e "${BOLD}${CYAN}neurex${NC} — NeurexQA Servis Yönetim CLI"
    echo ""
    echo -e "${BOLD}Komutlar:${NC}"
    echo "  up           Tüm servisleri başlat (backend + engine + watchdog)"
    echo "  down         Tüm servisleri durdur"
    echo "  restart      Yeniden başlat"
    echo "  status       Servis durumlarını göster"
    echo "  logs         Canlı log takibi (backend | engine | watchdog | all)"
    echo "  clean        Takılı Playwright süreçlerini temizle"
    echo "  install      Mac açılışında otomatik başlat (LaunchAgent kur)"
    echo "  uninstall    LaunchAgent'ı kaldır"
    echo ""
    echo -e "${BOLD}Örnekler:${NC}"
    echo "  neurex up"
    echo "  neurex status"
    echo "  neurex logs engine"
    echo "  neurex install"
    echo ""
}

# ── Router ────────────────────────────────────────────────────────────────────
case "${1:-help}" in
    up)        cmd_up ;;
    down)      cmd_down ;;
    restart)   cmd_restart ;;
    status)    cmd_status ;;
    logs)      cmd_logs "${2:-all}" ;;
    clean)     cmd_clean ;;
    install)   cmd_install ;;
    uninstall) cmd_uninstall ;;
    help|--help|-h) cmd_help ;;
    *)
        err "Bilinmeyen komut: ${1}"
        cmd_help
        exit 1
        ;;
esac
