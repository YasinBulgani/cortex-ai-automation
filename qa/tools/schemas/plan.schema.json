{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cortex.qa.plan",
  "title": "Test Plan",
  "type": "object",
  "required": ["id", "title", "milestone", "owner", "created", "scope", "exit_criteria"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^TP-\\d{4}\\.Q[1-4]-[A-Z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "milestone": { "type": "string", "pattern": "^R-\\d{4}\\.Q[1-4]$" },
    "owner": { "type": "string", "pattern": "^@[A-Za-z0-9_-]+$" },
    "created": { "type": "string", "format": "date" },
    "scope": {
      "type": "object",
      "required": ["include"],
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "suite": { "type": "string" },
              "priorities": {
                "type": "array",
                "items": { "enum": ["P0", "P1", "P2", "P3"] }
              },
              "cases": {
                "type": "array",
                "items": { "type": "string", "pattern": "^TC-[A-Z0-9]+-\\d{3,}$" }
              },
              "tags": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "tags": { "type": "array", "items": { "type": "string" } },
              "cases": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "configurations": {
      "type": "object",
      "properties": {
        "matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "browser": { "type": "string" },
              "env": { "type": "string" }
            }
          }
        }
      }
    },
    "exit_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
