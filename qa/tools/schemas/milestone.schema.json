{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cortex.qa.milestone",
  "title": "Milestone / Release",
  "type": "object",
  "required": ["id", "title", "target_date", "status", "exit_criteria"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^R-\\d{4}\\.Q[1-4]$" },
    "title": { "type": "string", "minLength": 1 },
    "target_date": { "type": "string", "format": "date" },
    "status": { "enum": ["planning", "in_progress", "closed", "cancelled"] },
    "scope": { "type": "string" },
    "exit_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "plans": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TP-\\d{4}\\.Q[1-4]-[A-Z0-9-]+$" }
    }
  }
}
