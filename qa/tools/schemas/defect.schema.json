{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cortex.qa.defect",
  "title": "Defect Mirror (GitHub Issue close-state snapshot)",
  "type": "object",
  "required": [
    "id",
    "title",
    "severity",
    "status",
    "found_in",
    "related_tc",
    "external",
    "opened",
    "closed",
    "reporter"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^GH-\\d+$" },
    "title": { "type": "string", "minLength": 1 },
    "severity": { "enum": ["S1", "S2", "S3", "S4"] },
    "status": { "const": "closed" },
    "found_in": { "type": "string", "pattern": "^TR-\\d{4}-\\d{2}-\\d{2}-[A-Z0-9-]+-\\d{3,}$" },
    "related_tc": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^TC-[A-Z0-9]+-\\d{3,}$" }
    },
    "external": { "type": "string", "format": "uri" },
    "opened": { "type": "string", "format": "date" },
    "closed": { "type": "string", "format": "date" },
    "fix_commit": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
    "reporter": { "type": "string", "pattern": "^@[A-Za-z0-9_-]+$" }
  }
}
