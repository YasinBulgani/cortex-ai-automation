# =====================================================
#  Test Automation Framework — environment template
#  Bu dosyayi .env olarak kopyalayin ve degerleri doldurun.
#  .env GIT'E COMMIT EDILMEZ (.gitignore'da).
# =====================================================

# --- AES sifresi (16/24/32 byte) ---
CORTEX_AES_KEY=changeMeInProd16

# --- DB credentials ---
DB1_PASSWORD=

# --- Cortex login ---
CORTEX_USERNAME=
CORTEX_PASSWORD=

# --- Dashboard ---
DASHBOARD_PORT=5001
DASHBOARD_HOST=0.0.0.0
DASHBOARD_SECRET=change-this-secret

# --- Maven binary path (installer override) ---
# MAVEN_HOME=
# JAVA_HOME=
