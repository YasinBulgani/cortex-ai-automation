# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/synthetic_bank
DB_POOL_SIZE=10

# App
APP_NAME=SyntheticBankData
APP_VERSION=2.0.0
DEBUG=true

# LLM
LLM_PROVIDER=openai  # openai, anthropic, ollama
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4
LLM_ENDPOINT=http://localhost:11434  # Ollama endpoint
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Server
HOST=0.0.0.0
PORT=8000
