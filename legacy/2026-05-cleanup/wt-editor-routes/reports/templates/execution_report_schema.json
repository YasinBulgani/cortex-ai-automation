{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BGTS Test Execution Report",
  "description": "Test execution raporu JSON formatı",
  "type": "object",
  "required": ["report_id", "execution_id", "project_id", "timing", "summary", "results"],
  "properties": {
    "report_id": { "type": "string", "format": "uuid" },
    "execution_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": "string", "format": "uuid" },
    "title": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "environment": {
      "type": "object",
      "properties": {
        "browser": { "type": "string", "enum": ["chromium", "firefox", "webkit"] },
        "base_url": { "type": "string", "format": "uri" },
        "os": { "type": "string" },
        "node_version": { "type": "string" },
        "python_version": { "type": "string" },
        "ci": { "type": "boolean" }
      }
    },
    "timing": {
      "type": "object",
      "required": ["started_at", "finished_at", "duration_seconds"],
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "duration_seconds": { "type": "number", "minimum": 0 }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed", "skipped", "pass_rate"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 100 },
        "severity_breakdown": {
          "type": "object",
          "patternProperties": {
            "^(critical|high|medium|low)$": {
              "type": "object",
              "properties": {
                "total": { "type": "integer" },
                "passed": { "type": "integer" },
                "failed": { "type": "integer" },
                "skipped": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_id", "title", "status", "duration_ms"],
        "properties": {
          "test_id": { "type": "string" },
          "scenario_id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "skipped", "broken"] },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "module": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "requirement_ids": { "type": "array", "items": { "type": "string" } },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "order": { "type": "integer" },
                "action": { "type": "string" },
                "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
                "duration_ms": { "type": "integer" },
                "detail": { "type": "string" },
                "error": { "type": "string" },
                "screenshot": { "type": "string" }
              }
            }
          },
          "error": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "message": { "type": "string" },
              "stack_trace": { "type": "string" },
              "screenshot": { "type": "string" },
              "trace_file": { "type": "string" }
            }
          },
          "root_cause": {
            "type": "object",
            "properties": {
              "category": {
                "type": "string",
                "enum": ["PRODUCT_BUG", "TEST_ISSUE", "ENVIRONMENT", "AUTOMATION_DEBT", "UNKNOWN"]
              },
              "subcategory": { "type": "string" },
              "description": { "type": "string" },
              "action": { "type": "string" },
              "assignee": { "type": "string" }
            }
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "properties": {
        "requirements_covered": { "type": "integer" },
        "requirements_total": { "type": "integer" },
        "coverage_percent": { "type": "number" },
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "total": { "type": "integer" },
              "covered": { "type": "integer" },
              "percent": { "type": "number" }
            }
          }
        }
      }
    },
    "trends": {
      "type": "object",
      "properties": {
        "previous_pass_rate": { "type": "number" },
        "delta": { "type": "number" },
        "direction": { "type": "string", "enum": ["improving", "stable", "declining"] },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "run_id": { "type": "string" },
              "date": { "type": "string", "format": "date" },
              "total": { "type": "integer" },
              "passed": { "type": "integer" },
              "pass_rate": { "type": "number" }
            }
          }
        }
      }
    },
    "traceability": {
      "type": "array",
      "description": "Requirement -> TestCase -> Result zinciri",
      "items": {
        "type": "object",
        "properties": {
          "requirement_id": { "type": "string" },
          "requirement_title": { "type": "string" },
          "test_ids": { "type": "array", "items": { "type": "string" } },
          "statuses": { "type": "array", "items": { "type": "string" } },
          "overall_status": { "type": "string" }
        }
      }
    }
  }
}
