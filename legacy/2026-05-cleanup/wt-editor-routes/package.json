{
  "name": "testwright-ai-monorepo",
  "private": true,
  "workspaces": [
    "apps/web",
    "ai-engine"
  ],
  "scripts": {
    "web:dev": "npm run dev --prefix apps/web",
    "web:build": "npm run build --prefix apps/web",
    "web:lint": "npm run lint --prefix apps/web",
    "web:start": "npm run start --prefix apps/web",
    "web:test": "npm run test --prefix apps/web",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --project=smoke",
    "test:e2e:regression": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --project=regression",
    "test:e2e:full": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --project=full",
    "test:e2e:service": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --project=service",
    "test:e2e:mobile": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --project=mobile",
    "test:e2e:headed": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --headed",
    "test:e2e:debug": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers PWDEBUG=1 playwright test",
    "test:e2e:trace": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --trace on",
    "test:e2e:staging": "TEST_ENV=staging PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --project=smoke",
    "test:e2e:firefox": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --project=firefox",
    "test:e2e:webkit": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --project=webkit",
    "test:e2e:cross-browser": "PLAYWRIGHT_BROWSERS_PATH=.pw-browsers playwright test --project=smoke --project=firefox --project=webkit",
    "test:bdd": "npx cucumber-js --config cucumber.mjs",
    "test:bdd:smoke": "npx cucumber-js --config cucumber.mjs --tags @smoke",
    "test:bdd:regression": "npx cucumber-js --config cucumber.mjs --tags @regression",
    "test:bdd:auth": "npx cucumber-js --config cucumber.mjs --tags @auth",
    "test:backend:smoke": "cd backend && ./.venv/bin/python -m pytest -m smoke -v --tb=short",
    "test:backend:service": "cd backend && ./.venv/bin/python -m pytest -m 'service or regression' -v",
    "test:backend:full": "cd backend && ./.venv/bin/python -m pytest --cov=app --cov-report=term-missing -v",
    "test:engine:unit": "cd engine && ./.venv/bin/python -m pytest tests/unit/ -m 'not ai' -v --tb=short",
    "test:engine:smoke": "cd engine && ./.venv/bin/python -m pytest -m smoke -v --tb=short",
    "test:engine:full": "cd engine && ./.venv/bin/python -m pytest tests/ -m 'not ai' -v",
    "test:engine:bdd": "cd engine && ./.venv/bin/python -m pytest tests/ -m bdd -v",
    "test:all:smoke": "npm run test:backend:smoke && npm run test:engine:unit && npm run test:e2e:smoke",
    "test:all:full": "npm run test:backend:full && npm run test:engine:full && npm run test:e2e:full",
    "report:open": "npx playwright show-report reports/e2e-html",
    "report:clean": "rm -rf reports/ && rm -rf e2e/.auth/",
    "seed": "cd backend && PYTHONPATH=. ./.venv/bin/python scripts/seed.py",
    "seed:demo": "cd backend && PYTHONPATH=. ./.venv/bin/python scripts/seed_demo.py",
    "seed:all": "cd backend && PYTHONPATH=. ./.venv/bin/python scripts/seed_all.py",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=./.pw-browsers playwright install chromium",
    "playwright:install:all": "PLAYWRIGHT_BROWSERS_PATH=./.pw-browsers playwright install chromium firefox webkit",
    "ai:select-tests": "./engine/.venv/bin/python scripts/ai_test_selector.py --changed-files \"$(git diff --name-only HEAD~1)\" --output-format text",
    "ai:report": "./engine/.venv/bin/python scripts/ai_report_generator.py --output-dir reports/",
    "ai:update-db": "./engine/.venv/bin/python scripts/update_learning_db.py --report reports/e2e-results.json --optimize",
    "ai:full-pipeline": "npm run test:e2e:smoke && npm run ai:update-db && npm run ai:report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@cucumber/cucumber": "^11.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  }
}
