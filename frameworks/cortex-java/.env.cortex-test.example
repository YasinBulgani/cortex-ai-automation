# Example env-specific config for the cortex-test environment.
# Copy to .env.cortex-test and customize.
# Activated via: mvn test -Dcortex.env=cortex-test
#                or CORTEX_ENV=cortex-test mvn test

# Base URL (overrides cortex.url / base.url from config.properties)
CORTEX_URL=https://cortex-test.bgtsai.com/

# Credentials (used by ${ENV:CORTEX_USERNAME:default} in .feature files)
CORTEX_USERNAME=test_user
CORTEX_PASSWORD_ALIAS=cortexTestUser

# Playwright settings (override defaults)
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT_MS=45000

# Feature flags this env supports (for assertions)
FEATURE_NEW_DASHBOARD=true
