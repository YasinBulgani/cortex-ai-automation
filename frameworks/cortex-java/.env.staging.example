# Example env-specific config for the staging environment.
# Copy to .env.staging and customize.
# Activated via: mvn test -Dcortex.env=staging

CORTEX_URL=https://cortex-staging.bgtsai.com/
CORTEX_USERNAME=staging_user
CORTEX_PASSWORD_ALIAS=cortexStagingUser
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=60000
FEATURE_NEW_DASHBOARD=false
