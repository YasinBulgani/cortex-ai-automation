{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bgts.local/schemas/dsl-action.json",
  "title": "BGTS DSL Action",
  "description": "Tek bir test DSL cümleciğinin (step definition) merkezi tanımı. Her cümlecik TR/EN alias'ları, parametreleri ve 3 dildeki implementasyon referanslarını içerir.",
  "type": "object",
  "required": ["id", "category", "description", "aliases", "implementations"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Benzersiz cümlecik kimliği (snake_case). Örn: click_button, fill_input, assert_visible"
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.]*$",
      "description": "Hiyerarşik kategori (nokta ile ayrılır). Örn: ui.click, api.http, assert.visibility, bgts.approval"
    },
    "description": {
      "type": "string",
      "minLength": 5,
      "description": "Cümleciğin ne yaptığının kısa açıklaması"
    },
    "aliases": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "tr": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "description": "Türkçe alias kalıpları. {param} veya {param:type} formatında parametre kullanılabilir."
        },
        "en": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "description": "İngilizce alias kalıpları."
        }
      }
    },
    "parameters": {
      "type": "array",
      "description": "Cümlecikteki {param} yer tutucularının tanımı.",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$" },
          "type": { "type": "string", "enum": ["string", "int", "float", "bool", "locator", "url", "duration_ms", "json"] },
          "description": { "type": "string" },
          "required": { "type": "boolean", "default": true },
          "default": {},
          "examples": { "type": "array" }
        }
      }
    },
    "implementations": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "description": "Her dil için: hangi dosyada, hangi sınıf/fonksiyon bu cümleciği uyguluyor",
      "properties": {
        "python": {
          "type": "object",
          "required": ["source_file"],
          "additionalProperties": false,
          "properties": {
            "module": { "type": "string", "description": "Python modül yolu (engine.steps.click_steps gibi)" },
            "function": { "type": "string", "description": "Fonksiyon adı" },
            "source_file": { "type": "string", "description": "Projede göreceli yol" },
            "pattern": { "type": "string", "description": "@given/@when/@then pattern'i (opsiyonel, alias'tan üretilir)" }
          }
        },
        "java": {
          "type": "object",
          "required": ["source_file"],
          "additionalProperties": false,
          "properties": {
            "class": { "type": "string", "description": "Java sınıf yolu (stepdefinitions.ClickSteps gibi)" },
            "method": { "type": "string" },
            "function": { "type": "string", "description": "method alias'ı (auto-generated YAML'ler için)" },
            "source_file": { "type": "string" },
            "pattern": { "type": "string" }
          }
        },
        "typescript": {
          "type": "object",
          "required": ["source_file"],
          "additionalProperties": false,
          "properties": {
            "module": { "type": "string", "description": "TS modül yolu (web-steps gibi)" },
            "function": { "type": "string" },
            "source_file": { "type": "string" },
            "pattern": { "type": "string" }
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
      "description": "Aranabilir etiketler (ui, api, auth, smoke, wip, deprecated...)",
      "uniqueItems": true
    },
    "since": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Eklendiği tarih (YYYY-MM-DD)"
    },
    "deprecated": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "required": ["replacement"],
          "properties": {
            "replacement": { "type": "string", "description": "Yerine kullanılacak cümlecik id'si" },
            "since": { "type": "string" },
            "reason": { "type": "string" }
          }
        }
      ]
    },
    "examples": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Gherkin senaryo örnekleri (kopyalanabilir)"
    },
    "notes": {
      "type": "string",
      "description": "Ek uyarılar, bilinmesi gerekenler"
    }
  }
}
