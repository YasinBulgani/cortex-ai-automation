{
  "name": "cortex-ai-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Cortex AI Automation — Test automation monorepo (Java framework + Next.js web + Python dashboard)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules/.cache",
    "web:dev": "npm run dev --workspace apps/web",
    "web:build": "npm run build --workspace apps/web",
    "web:start": "npm run start --workspace apps/web",
    "framework:compile": "cd framework && ./mvnw -DskipTests compile",
    "framework:test": "cd framework && ./mvnw test",
    "framework:recorder": "cd framework && ./mvnw exec:java -Dexec.mainClass=recorder.RecorderMain",
    "dashboard:start": "cd framework && source .venv/bin/activate && cd python_server && python flask_api.py",
    "installer:mac": "bash installer/mac/build-dmg.sh",
    "installer:win": "echo 'Run on Windows: installer\\\\windows\\\\build.bat'"
  },
  "devDependencies": {
    "turbo": "^2.9.12"
  },
  "packageManager": "npm@10.0.0",
  "overrides": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1"
  }
}
