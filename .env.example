# ═══════════════════════════════════════════════════════════════════════════════
# TestwrightAI — Merkezi Ortam Değişkenleri
#
# Kullanım:
#   cp .env.example .env
#   # Ardından tüm CHANGEME değerlerini gerçek değerlerle doldurun
#   # .env dosyasını asla git'e commit etmeyin
#
# Güvenli secret üretimi:
#   openssl rand -base64 64   →  JWT_SECRET, SESSION_SECRET için
#   openssl rand -hex 32      →  INTERNAL KEY'ler için
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Ortam ───────────────────────────────────────────────────────────────────
# "development" | "staging" | "production"
APP_ENV=development
DEBUG=false

# ─── Ürün Markası (tek kaynak — UX-F1-105) ──────────────────────────────────
# Frontend + Backend bu iki değişkeni aynı tutar; rebrand tek yerden yapılır.
# Boş bırakılırsa frontend "Visium", backend "Sentetik Veri Platformu" default'ına
# düşer. Tutarlı marka için ikisini de aynı değere ayarlayın.
#
#   APP_NAME=TestwrightAI
#   NEXT_PUBLIC_APP_NAME=TestwrightAI
#
# Not: NEXT_PUBLIC_* env'leri Next.js build sırasında inline edilir; frontend
# kodu üretildikten sonra değiştirilemez (yeniden build gerekir).
APP_NAME=
NEXT_PUBLIC_APP_NAME=

# ─── Veritabanı (PostgreSQL) ─────────────────────────────────────────────────
# Geliştirme: local için ayrı, düşük yetkili bir kullanıcı oluşturun
# Production: RDS / Cloud SQL bağlantı string'i kullanın
DATABASE_URL=postgresql+psycopg2://twai_user:twai_pass@127.0.0.1:5432/syndata_db
POSTGRES_USER=twai_user
POSTGRES_PASSWORD=twai_pass                   # CHANGEME — prod'da güçlü şifre
POSTGRES_DB=syndata_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
# Docker Compose içinden Redis erişimi
DOCKER_REDIS_URL=redis://redis:6379/0
# Prod'da auth ekleyin: redis://:REDIS_PASSWORD@host:6379/0
REDIS_PASSWORD=

# ─── Backend (FastAPI — port 8000) ───────────────────────────────────────────
# KRİTİK: Prod/staging'de mutlaka değiştirin; en az 64 karakter
# Üretim: openssl rand -base64 64
JWT_SECRET=CHANGEME-minimum-64-chars-use-openssl-rand-base64-64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15
ALLOW_SELF_REGISTRATION=false

# CORS: Prod'da gerçek domain ile kısıtlayın
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ─── Dahili Güvenlik Anahtarları ─────────────────────────────────────────────
# Backend ↔ Engine haberleşmesi için; dışarıya açılmamalı
# Üretim: openssl rand -hex 32
ENGINE_INTERNAL_KEY=CHANGEME-engine-internal-key
# Backend ↔ AI Gateway haberlesmesi icin; browser'a asla acilmaz
# Uretim: openssl rand -hex 32
GATEWAY_INTERNAL_KEY=CHANGEME-gateway-internal-key

# ─── Engine (Flask — Test Otomasyon Motoru, port 5001) ───────────────────────
ENGINE_PORT=5001
ENGINE_BASE_URL=http://127.0.0.1:5001
ENGINE_SECRET_KEY=CHANGEME-engine-secret-key   # openssl rand -hex 32

# Readiness probe'unda engine kontrolü zorunlu mu?
# "true" → engine erişilemezse /ready 503 döner (önerilen, Kubernetes için)
# "false" → engine sorunu yalnızca uyarı olur (standalone geliştirme ortamı)
ENGINE_REQUIRED_FOR_READY=true

# ─── Tarayıcı Otomasyon ─────────────────────────────────────────────────────
BROWSER=chromium
HEADLESS=true                  # Prod/CI'da true; local geliştirmede false
BASE_URL=https://example.com
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000

# ─── CI/CD Entegrasyonu ──────────────────────────────────────────────────────
# Dış CI pipeline'larının test tetiklemesi için güvenli token
# POST /cicd/trigger/{project_id} endpoint'ini korur
# Üretim: openssl rand -hex 32
# Boş bırakılırsa doğrulama atlanır (yalnızca geliştirme için)
CI_TRIGGER_TOKEN=CHANGEME-ci-trigger-token

# GitHub webhook imzası doğrulaması (GitHub → Settings → Webhooks → Secret)
GITHUB_WEBHOOK_SECRET=
# GitLab webhook token doğrulaması
GITLAB_WEBHOOK_TOKEN=
# Jenkins webhook token
JENKINS_WEBHOOK_TOKEN=

# ─── Visium Farm (Mobil Test) ────────────────────────────────────────────────
MOBILE_ARTIFACTS_DIR=./mobile_uploads
# Gerçek cihaz farm entegrasyonu (isteğe bağlı)
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
BROWSERSTACK_BUILD="Visium Farm Build"
BROWSERSTACK_PROJECT="TestwrightAI Visium Operations"
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=
SAUCE_REGION=eu-central

# ─── Frontend (Next.js — port 3000) ─────────────────────────────────────────
# Browser istemcileri engine'e dogrudan degil backend proxy uzerinden gider.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
NEXT_PUBLIC_ENGINE_BASE=/api/v1/automation/proxy
# Prod'da domain:
# NEXT_PUBLIC_API_BASE=
# NEXT_PUBLIC_ENGINE_BASE=/api/v1/automation/proxy

# Login ekranında demo hesapları göster (yalnızca yerel demo ortamları için).
# Üretim build'inde kesinlikle "false" veya tanımsız kalmalıdır.
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false

# Next.js middleware sunucu tarafı rota koruması.
# "false" → middleware devre dışı (acil çıkış kapısı); "true" veya tanımsız → aktif
NEXT_PUBLIC_AUTH_MIDDLEWARE_ENABLED=true

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Sağlayıcı seçimi: "openai" | "anthropic" | "ollama" | "auto"
AI_PROVIDER=ollama
# false ise secili provider eksik oldugunda fallback yapilmaz ve acik hata verilir
ALLOW_PROVIDER_FALLBACK=false

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Groq (ücretsiz: https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192
GROQ_ENABLED=true

# Gemini (ücretsiz: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_ENABLED=true

# Ollama (yerel LLM — Docker host erişimi)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_ENABLED=true
OLLAMA_MODEL_ANALYST=qwen2.5:14b
OLLAMA_MODEL_FAST=llama3.1:8b
OLLAMA_MODEL_CODER=qwen2.5-coder:7b

# ─── AI Arka Plan Servisi ────────────────────────────────────────────────────
AI_BACKGROUND_ENABLED=true
AI_BACKGROUND_INTERVAL_SECONDS=900
AI_BACKGROUND_START_DELAY_SECONDS=60

# ─── n8n (İş Akışı Otomasyonu) ───────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ─── Monitoring & Observability ─────────────────────────────────────────────
# Sentry (hata izleme) — https://sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=development   # development | staging | production
SENTRY_TRACES_SAMPLE_RATE=0.1   # Prod'da 0.05-0.1 önerilir

# Prometheus metrikleri
PROMETHEUS_ENABLED=false         # Prod'da true
GRAFANA_ADMIN_PASSWORD=
ALERTMANAGER_WEBHOOK_URL=
G4F_ENABLED=false

# ─── E-posta ─────────────────────────────────────────────────────────────────
# Backend: "console" (default, dev) | "memory" (test) | "smtp" (prod)
# console: E-posta log'a yazılır, gerçekten gönderilmez.
# smtp:    SMTP_* değişkenleri zorunludur.
EMAIL_BACKEND=console
EMAIL_FROM=no-reply@testwright.ai

# Şifre sıfırlama linklerinde kullanılacak public URL (frontend kökü).
# Prod: https://app.example.com
APP_PUBLIC_URL=http://localhost:3000

# SMTP — yalnızca EMAIL_BACKEND=smtp iken kullanılır.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ─── Rate Limiting (backend) ─────────────────────────────────────────────────
# Varsayılan: login 5/dakika, register 3/dakika. Dev'de tekrarlı login
# denemeleri 429 verir; geliştirme için yüksek tutmak isteyebilirsiniz.
# Prod'da varsayılana yakın kalın.
# RATE_LIMIT_LOGIN=1000/minute
# RATE_LIMIT_REGISTER=1000/minute

# ─── Security Scanning ───────────────────────────────────────────────────────
# Semgrep Cloud token — semgrep-secrets-runbook'ta tanımlanan CI taramaları için
# https://semgrep.dev/orgs/ → Settings → Tokens
SEMGREP_APP_TOKEN=

# ─── Eval / Quality Reports ──────────────────────────────────────────────────
# Quality service ve eval CLI tarafından kullanılan rapor dizinleri (P2 ENV)
# Varsayılan: reports/evals — production'da mutlak yol kullanın
ENGINE_EVAL_REPORTS_DIR=
EVAL_REPORTS_DIR=
